import objetos.*
import game.*
describe "test de futbolito" {
  test "test de inicio" {
    const inicio = game.at(0,5)
    assert.notEquals(inicio, lionel.position())
    lionel.inicio()
    assert.equals(inicio, lionel.position())
  }
}

describe "Tests para el juego futbolito" {
  test "Lionel busca la pelota" {
    assert.notEquals(pelota.position(),lionel.position())
    lionel.buscarla()
    assert.equals(pelota.position(),lionel.position())
  }
}

